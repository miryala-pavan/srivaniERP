# ─────────────────────────────────────────────────────────────────────────────
# Srivani ERP — Production .env for Hetzner VPS
# Copy this to /var/srivani/app/backend/.env and fill in the values
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL running in Docker on same server
DATABASE_URL="postgresql://srivani:CHANGE_THIS_PASSWORD@localhost:5432/srivanidb"

JWT_SECRET=GENERATE_A_STRONG_64_CHAR_RANDOM_SECRET
JWT_EXPIRES_IN=12h

PORT=4001
NODE_ENV=production

# Your Vercel frontend URL
FRONTEND_URL=https://srivani-erp.vercel.app

# Storage (on the VPS — created by server-setup.sh)
PRODUCT_IMAGES_DIR=/var/srivani/storage/product-images
PAYMENT_PROOFS_DIR=/var/srivani/storage/payment-proofs
