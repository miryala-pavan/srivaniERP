generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ─── BUSINESS ───────────────────────────────────────
model Business {
  id           String   @id @default(cuid())
  name         String
  gstin        String?
  stateCode    String   @default("36")
  stateName    String   @default("Telangana")
  address      String?
  phone        String?
  email        String?
  fssaiLicense String?
  fssaiExpiry  DateTime?

  // Tax IDs
  pan               String?
  tan               String?
  professionalTaxNo String?

  // Food & Health
  drugLicense       String?
  drugLicenseExpiry DateTime?

  // Trade & Premises
  tradeLicense             String?
  tradeLicenseExpiry       DateTime?
  shopEstablishmentLicense String?
  shopEstablishmentExpiry  DateTime?
  fireSafetyNoc            String?
  fireSafetyNocExpiry      DateTime?

  // Operational
  weightsAndMeasuresLicense String?
  weightsAndMeasuresExpiry  DateTime?
  liquorLicense             String?
  liquorLicenseExpiry       DateTime?

  // Other Registrations
  udyamRegistration String?
  cin               String?
  iecCode           String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches            Branch[]
  users               User[]
  products            Product[]
  suppliers           Supplier[]
  customers           Customer[]
  taxes               Tax[]
  departments         Department[]
  categories          Category[]
  brands              Brand[]
  financialYears      FinancialYear[]
  posCounters         PosCounter[]
  expenses            Expense[]
  notifications       Notification[]
  dayClosures         DayClosure[]
  productPlus         ProductPlu[]
  supplierItemAliases SupplierItemAlias[]
  supplierAdvances    SupplierAdvance[]
  supplierCreditNotes SupplierCreditNote[]
  supplierPayments    SupplierPayment[]
  bankAccounts        BankAccount[]
  bankTransactions    BankTransaction[]
  onlineOrders        OnlineOrder[]
  waIncomingLists     WaIncomingList[]
  systemSettings      SystemSetting[]

  @@map("business")
}

// ─── BRANCH ─────────────────────────────────────────
model Branch {
  id         String   @id @default(cuid())
  businessId String
  name       String
  address    String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business       Business       @relation(fields: [businessId], references: [id])
  posCounters    PosCounter[]
  salesBills     SalesBill[]
  purchases      Purchase[]
  stockLedger    StockLedger[]
  productBatches ProductBatch[]

  @@map("branch")
}

// ─── FINANCIAL YEAR ──────────────────────────────────
model FinancialYear {
  id         String    @id @default(cuid())
  businessId String
  fyCode     String
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean   @default(true)
  isClosed   Boolean   @default(false)
  closedAt   DateTime?

  // Snapshot captured at year-end close (for year comparison report)
  closingTotalSales       Decimal? @db.Decimal(15,2)
  closingTotalPurchases   Decimal? @db.Decimal(15,2)
  closingSupplierDues     Decimal? @db.Decimal(15,2)
  closingStockValue       Decimal? @db.Decimal(15,2)
  closingBankBalance      Decimal? @db.Decimal(15,2)

  createdAt  DateTime  @default(now())

  business   Business    @relation(fields: [businessId], references: [id])
  billSeries BillSeries[]
  salesBills SalesBill[]

  @@map("financial_year")
}

// ─── USER & AUTH ─────────────────────────────────────
model User {
  id                  String     @id @default(cuid())
  businessId          String
  username            String
  email               String?
  passwordHash        String
  fullName            String
  phone               String?
  role                UserRole   @default(CASHIER)
  status              UserStatus @default(ACTIVE)
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  pin                 String?
  counterId           String?
  assignedCounterIds  String?
  createdById         String?
  createdByName       String?
  updatedById         String?
  updatedByName       String?
  deletedAt           DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  business   Business   @relation(fields: [businessId], references: [id])
  posShifts  PosShift[]
  salesBills SalesBill[]

  @@unique([businessId, username])
  @@map("user")
}

enum UserRole {
  SUPER_ADMIN
  BRANCH_MANAGER
  CASHIER
  PURCHASE_CHECKER
  ACCOUNTS_PERSON
  FLOOR_SUPERVISOR
  PACKING_STAFF
  SALES_REP
  VIEWER
  CA
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  LOCKED
}

// ─── TAX ─────────────────────────────────────────────
model Tax {
  id         String   @id @default(cuid())
  businessId String
  taxName    String
  taxCode    String
  taxRate    Decimal  @db.Decimal(5, 2)
  hsnCode    String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  business      Business       @relation(fields: [businessId], references: [id])
  products      Product[]
  salesItems    SalesItem[]
  purchaseItems PurchaseItem[]

  @@unique([businessId, taxCode])
  @@map("tax")
}

// ─── DEPARTMENT ──────────────────────────────────────
model Department {
  id          String     @id @default(cuid())
  businessId  String
  name        String
  code        String
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  business    Business   @relation(fields: [businessId], references: [id])
  categories  Category[]
  products    Product[]

  @@unique([businessId, code])
  @@index([businessId])
  @@map("department")
}

// ─── CATEGORY ────────────────────────────────────────
model Category {
  id           String   @id @default(cuid())
  businessId   String
  departmentId String?
  name         String
  code         String
  label        String
  parentId     String?
  hsnCode      String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  isReturnableDefault Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business   Business    @relation(fields: [businessId], references: [id])
  department Department? @relation(fields: [departmentId], references: [id])
  products   Product[]
  parent     Category?   @relation("SubCategories", fields: [parentId], references: [id])
  children   Category[]  @relation("SubCategories")

  @@unique([businessId, code])
  @@index([businessId, parentId])
  @@index([businessId, departmentId])
  @@map("category")
}

// ─── BRAND ───────────────────────────────────────────
model Brand {
  id         String   @id @default(cuid())
  businessId String
  name       String
  code       String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id])
  products Product[]

  @@unique([businessId, name])
  @@index([businessId])
  @@map("brand")
}

// ─── PRODUCT ─────────────────────────────────────────
model Product {
  id                  String   @id @default(cuid())
  businessId          String
  departmentId        String?
  categoryId          String?
  brandId             String?
  taxId               String
  productCode         String?           // 000001 — auto-generated, never changes
  name                String
  shortName           String?           // Fortune Oil 1L
  barcode             String?           // primary barcode (backward compat)
  hsnCode             String
  unitOfMeasure       String   @default("PCS")
  productType         String   @default("STANDARD") // STANDARD/LOOSE/REPACKED/RAW_MATERIAL/PACKAGING
  mrp                 Decimal  @db.Decimal(15, 2)
  sellingPrice        Decimal  @db.Decimal(15, 2)
  costPrice           Decimal? @db.Decimal(15, 2)
  gstRatePercent      Decimal? @db.Decimal(5, 2)
  reorderLevel        Decimal  @db.Decimal(15, 3) @default(10)
  minimumStockLevel   Decimal  @db.Decimal(15, 3) @default(0)
  reorderQuantity     Decimal  @db.Decimal(15, 3) @default(0)
  maximumStockLevel   Decimal  @db.Decimal(15, 3) @default(0)
  leadTimeDays        Int      @default(2)
  minSellingQty       Decimal  @db.Decimal(15, 3) @default(1)
  moqFromSupplier     Decimal  @db.Decimal(15, 3) @default(1)
  allowDecimalQty     Boolean  @default(false)
  allowNegativeStock  Boolean  @default(false)
  allowBelowMargin    Boolean  @default(false)
  isForSale           Boolean  @default(true)
  isForPurchase       Boolean  @default(true)
  isRepackingItem     Boolean  @default(false)
  isRepackedProduct   Boolean  @default(false)
  repackYieldPct      Decimal  @db.Decimal(5, 2) @default(98)
  isRawMaterial       Boolean  @default(false)
  isPackagingMaterial Boolean  @default(false)
  isPerishable        Boolean  @default(false)
  expiryTracking      Boolean  @default(false)
  shelfLifeDays       Int?
  nearExpiryAlertDays Int?
  stockValuation      String   @default("FIFO") // FIFO/LIFO/WEIGHTED_AVG
  preferredSupplierId String?
  aisle               String?
  rackNumber          String?
  shelfPosition       String?  // TOP/MIDDLE/BOTTOM
  binCode             String?  // auto: aisle-rack-shelf
  isReturnable         Boolean  @default(true)
  returnPeriodDays     Int      @default(7)
  nonReturnableReason  String?
  availableOnline      Boolean  @default(false)
  imageUrl             String?
  description          String?
  keywords             String?
  defaultPackSize      Int      @default(1)
  brandName            String?
  pluAutoBarcode       Boolean  @default(false)
  purchaseUnit         String   @default("PCS")
  stockUnit            String   @default("PCS")
  cessRate             Decimal  @db.Decimal(5, 2) @default(0)
  totalStock           Decimal  @db.Decimal(15, 3) @default(0)
  isActive             Boolean  @default(true)
  isManuallyDisabled  Boolean   @default(false)
  disabledById        String?
  disabledAt          DateTime?
  disabledReason      String?
  autoInactiveReason  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  business        Business           @relation(fields: [businessId], references: [id])
  department      Department?        @relation(fields: [departmentId], references: [id])
  category        Category?          @relation(fields: [categoryId], references: [id])
  brand           Brand?             @relation(fields: [brandId], references: [id])
  tax             Tax                @relation(fields: [taxId], references: [id])
  salesItems      SalesItem[]
  purchaseItems   PurchaseItem[]
  stockLedger     StockLedger[]
  barcodes        ProductBarcode[]
  prices          ProductPrice[]
  batches         ProductBatch[]
  plusList        ProductPlu[]
  supplierAliases SupplierItemAlias[]
  productImages   ProductImage[]
  groupMemberships ProductGroupMember[]

  @@unique([businessId, barcode])
  @@unique([businessId, productCode])
  @@index([businessId, isActive])
  @@index([barcode])
  @@index([businessId, productCode])
  // Trigram GIN indexes — keep "contains anywhere" search (ILIKE '%term%') fast at scale
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([keywords(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("product")
}

// ─── PRODUCT GROUPS (storefront size/variant picker) ─
model ProductGroup {
  id         String   @id @default(cuid())
  businessId String
  name       String
  createdAt  DateTime @default(now())
  members    ProductGroupMember[]
  @@index([businessId])
  @@map("product_group")
}

model ProductGroupMember {
  id           String   @id @default(cuid())
  groupId      String
  productId    String
  displayLabel String
  sortOrder    Int      @default(0)
  group   ProductGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
  @@unique([groupId, productId])
  @@index([productId])
  @@map("product_group_member")
}

// ─── PRODUCT IMAGE ───────────────────────────────────
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_image")
}

// ─── PRODUCT BARCODE ─────────────────────────────────
model ProductBarcode {
  id           String   @id @default(cuid())
  productId    String
  businessId   String
  pluId        String?
  barcodeType  String   @default("EAN13") // EAN13/EAN8/CODE128/INTERNAL/SUPPLIER
  barcodeValue String
  isPrimary    Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  product Product     @relation(fields: [productId], references: [id])
  plu     ProductPlu? @relation(fields: [pluId], references: [id])

  @@unique([businessId, barcodeValue])
  @@index([productId])
  @@index([pluId])
  @@map("product_barcode")
}

// ─── PRODUCT PRICE LIST ──────────────────────────────
model ProductPrice {
  id              String    @id @default(cuid())
  productId       String
  businessId      String
  priceListType   String    @default("RETAIL") // RETAIL/WHOLESALE/ONLINE/STAFF
  costPrice       Decimal   @db.Decimal(15, 2) @default(0)
  sellingPrice    Decimal   @db.Decimal(15, 2)
  mrp             Decimal   @db.Decimal(15, 2)
  minSellingPrice Decimal   @db.Decimal(15, 2) @default(0)
  maxDiscountPct  Decimal   @db.Decimal(5, 2)  @default(5)
  effectiveFrom   DateTime  @default(now())
  effectiveTo     DateTime?
  createdAt       DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, priceListType])
  @@map("product_price")
}

// ─── PRODUCT BATCH ───────────────────────────────────
model ProductBatch {
  id              String    @id @default(cuid())
  productId       String
  branchId        String
  purchaseId      String?
  purchaseItemId  String?
  batchNumber     String?
  manufactureDate DateTime?
  expiryDate      DateTime?
  purchaseDate    DateTime  @default(now())
  quantityIn      Decimal   @db.Decimal(15, 3)
  quantityOut     Decimal   @db.Decimal(15, 3) @default(0)
  remainingQty    Decimal   @db.Decimal(15, 3)
  costPrice       Decimal   @db.Decimal(15, 2)
  rackLocation    String?
  status          String    @default("ACTIVE") // ACTIVE/DEPLETED/EXPIRED
  createdAt       DateTime  @default(now())

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@index([productId, branchId])
  @@index([expiryDate])
  @@map("product_batch")
}

// ─── SUPPLIER ─────────────────────────────────────────
model Supplier {
  id                 String   @id @default(cuid())
  businessId         String
  name               String
  gstin              String?
  phone              String?
  email              String?
  address            String?
  stateCode          String?
  paymentTermsDays   Int      @default(0)
  creditLimit        Decimal  @db.Decimal(15, 2) @default(0)
  isGstRegistered    Boolean  @default(true)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  openingBalance     Decimal   @db.Decimal(12, 2) @default(0)
  openingBalanceDate DateTime?
  openingBalanceType String    @default("DEBIT")
  openingBalanceNote String?

  // Alternate names as they appear in bank statements — used for auto-matching
  bankAliases        String[]  @default([])

  // Payee type — distinguishes trade suppliers from rent/loan/other payees
  supplierType       String    @default("SUPPLIER") // SUPPLIER | RENT | LOAN | OTHER

  // Legacy single bank account fields (kept for backwards compat)
  bankAccountNumber  String?
  bankIfscCode       String?
  bankBankName       String?
  bankBranchName     String?

  business     Business             @relation(fields: [businessId], references: [id])
  purchases    Purchase[]
  itemAliases  SupplierItemAlias[]
  advances     SupplierAdvance[]
  creditNotes  SupplierCreditNote[]
  payments     SupplierPayment[]
  bankAccounts SupplierBankAccount[]

  @@index([businessId])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("supplier")
}

model SupplierBankAccount {
  id            String   @id @default(cuid())
  businessId    String
  supplierId    String
  accountNumber String
  bankName      String
  branchName    String?
  ifscCode      String?
  isPrimary     Boolean  @default(false)
  transferLimit Decimal? @db.Decimal(15, 2)
  notes         String?
  createdAt     DateTime @default(now())

  supplier  Supplier @relation(fields: [supplierId], references: [id])

  @@index([supplierId])
  @@index([businessId])
  @@map("supplier_bank_account")
}

// ─── CUSTOMER ─────────────────────────────────────────
model Customer {
  id                 String          @id @default(cuid())
  businessId         String
  name               String
  phone              String?
  email              String?
  gstin              String?
  address            String?
  stateCode          String?
  customerType       String          @default("REGULAR")
  creditLimit        Decimal         @db.Decimal(15, 2) @default(0)
  outstandingBalance Decimal         @db.Decimal(15, 2) @default(0)
  loyaltyPoints      Int             @default(0)
  isActive           Boolean         @default(true)
  // Extended fields
  customerCode       String?
  passwordHash       String?
  channel            CustomerChannel @default(POS)
  status             CustomerStatus  @default(ACTIVE)
  companyName        String?
  billingAddress     String?
  openingBalance     Decimal         @db.Decimal(15, 2) @default(0)
  whatsappOptIn      Boolean         @default(false)
  smsOptIn           Boolean         @default(false)
  emailOptIn         Boolean         @default(false)
  dateOfBirth        DateTime?
  anniversary        DateTime?
  customerGroup      String?
  consentGivenAt     DateTime?
  isSystemDefault    Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  business   Business          @relation(fields: [businessId], references: [id])
  salesBills SalesBill[]
  addresses  CustomerAddress[]
  payments   CustomerPayment[]

  @@unique([businessId, customerCode])
  @@index([businessId, phone])
  @@index([businessId, isActive])
  @@index([name(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("customer")
}

enum CustomerChannel {
  POS
  ONLINE
  BOTH
}

enum CustomerStatus {
  ACTIVE
  BLOCKED
  INACTIVE
}

// ─── BILL SERIES ──────────────────────────────────────
model BillSeries {
  id              String   @id @default(cuid())
  businessId      String
  financialYearId String
  billType        String   @default("TAX_INVOICE") // TAX_INVOICE / RETAIL_INVOICE / ESTIMATE
  seriesPrefix    String   @default("GST/")
  currentNumber   Int      @default(0)
  numberFormat    String   @default("0000")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  financialYear FinancialYear @relation(fields: [financialYearId], references: [id])
  salesBills    SalesBill[]

  @@unique([businessId, financialYearId, billType])
  @@map("bill_series")
}

// ─── SALES BILL ───────────────────────────────────────
model SalesBill {
  id              String      @id @default(cuid())
  businessId      String
  branchId        String
  financialYearId String
  billSeriesId    String?
  billNumber      String?
  billDate        DateTime    @default(now())
  customerId      String?
  customerName    String?
  customerPhone   String?
  customerGstin   String?
  supplyStateCode String?
  saleType        SaleType    @default(CASH)
  paymentMode     PaymentMode @default(CASH)
  subtotalAmount  Decimal     @db.Decimal(15, 2) @default(0)
  discountAmount  Decimal     @db.Decimal(15, 2) @default(0)
  taxableAmount   Decimal     @db.Decimal(15, 2) @default(0)
  cgstTotal       Decimal     @db.Decimal(15, 2) @default(0)
  sgstTotal       Decimal     @db.Decimal(15, 2) @default(0)
  igstTotal       Decimal     @db.Decimal(15, 2) @default(0)
  totalTaxAmount  Decimal     @db.Decimal(15, 2) @default(0)
  grandTotal      Decimal     @db.Decimal(15, 2) @default(0)
  paidAmount      Decimal     @db.Decimal(15, 2) @default(0)
  balanceAmount   Decimal     @db.Decimal(15, 2) @default(0)
  billType          String      @default("TAX_INVOICE") // TAX_INVOICE / RETAIL_INVOICE / ESTIMATE
  isB2B             Boolean     @default(false)
  estimateStatus    String?     // OPEN / CONVERTED / EXPIRED / CANCELLED
  validityDate      DateTime?
  convertedToBillId String?
  convertedAt       DateTime?
  status          BillStatus  @default(DRAFT)
  counterId       String?
  shiftId         String?
  createdById     String?
  notes           String?
  // Multi-payment breakdown
  cashAmount      Decimal?    @db.Decimal(15, 2)
  upiAmount       Decimal?    @db.Decimal(15, 2)
  cardAmount      Decimal?    @db.Decimal(15, 2)
  // Void
  isVoided        Boolean     @default(false)
  voidedAt        DateTime?
  voidedById      String?
  voidedByName    String?
  voidReason      String?
  replacedByBillId String?
  // Bill-time snapshots — immutable after creation
  cashierName       String?
  counterName       String?
  businessName      String?
  businessGstin     String?
  businessAddress   String?
  financialYearCode String?
  cessTotal               Decimal @db.Decimal(15, 2) @default(0)
  isHistorical            Boolean @default(false)
  loyaltyPointsEarned     Int     @default(0)
  loyaltyPointsRedeemed   Int     @default(0)
  loyaltyDiscount         Decimal @db.Decimal(10, 2) @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  branch           Branch           @relation(fields: [branchId], references: [id])
  financialYear    FinancialYear    @relation(fields: [financialYearId], references: [id])
  customer         Customer?        @relation(fields: [customerId], references: [id])
  createdBy        User?            @relation(fields: [createdById], references: [id])
  billSeries       BillSeries?      @relation(fields: [billSeriesId], references: [id])
  posCounter       PosCounter?      @relation(fields: [counterId], references: [id])
  posShift         PosShift?        @relation(fields: [shiftId], references: [id])
  items            SalesItem[]
  customerPayments CustomerPayment[]

  @@index([branchId, billDate])
  @@index([status])
  @@index([customerId])
  @@map("sales_bill")
}

enum SaleType {
  CASH
  CREDIT
}

enum PaymentMode {
  CASH
  UPI
  CARD
  CHEQUE
  SPLIT
}

enum BillStatus {
  DRAFT
  FINAL
  CANCELLED
}

// ─── SALES ITEM ───────────────────────────────────────
model SalesItem {
  id              String  @id @default(cuid())
  billId          String
  productId       String
  taxId           String
  productName     String
  hsnCode         String?
  quantity        Decimal @db.Decimal(15, 3)
  unitPrice       Decimal @db.Decimal(15, 2)
  discountPercent Decimal @db.Decimal(5, 2)  @default(0)
  discountAmount  Decimal @db.Decimal(15, 2) @default(0)
  taxableAmount   Decimal @db.Decimal(15, 2) @default(0)
  gstRatePercent  Decimal @db.Decimal(5, 2)  @default(0)
  cgstAmount      Decimal @db.Decimal(15, 2) @default(0)
  sgstAmount      Decimal @db.Decimal(15, 2) @default(0)
  igstAmount      Decimal @db.Decimal(15, 2) @default(0)
  totalAmount     Decimal  @db.Decimal(15, 2)
  unitOfMeasure   String?
  mrp             Decimal? @db.Decimal(15, 2)   // snapshot at time of sale
  // Price override
  isPriceOverridden Boolean @default(false)
  originalPrice   Decimal? @db.Decimal(15, 2)
  overrideReason  String?
  cessAmount      Decimal  @db.Decimal(15, 2) @default(0)

  bill    SalesBill @relation(fields: [billId], references: [id])
  product Product   @relation(fields: [productId], references: [id])
  tax     Tax       @relation(fields: [taxId], references: [id])

  @@map("sales_item")
}

// ─── PURCHASE / GRN ───────────────────────────────────
model Purchase {
  id              String         @id @default(cuid())
  businessId      String
  branchId        String
  supplierId      String
  supplierName    String
  supplierGstin   String?
  grnNumber       String?
  invoiceNumber   String
  invoiceDate     DateTime
  taxableAmount   Decimal        @db.Decimal(15, 2) @default(0)
  totalTaxAmount  Decimal        @db.Decimal(15, 2) @default(0)
  cgstTotal       Decimal        @db.Decimal(15, 2) @default(0)
  sgstTotal       Decimal        @db.Decimal(15, 2) @default(0)
  igstTotal       Decimal        @db.Decimal(15, 2) @default(0)
  grandTotal      Decimal        @db.Decimal(15, 2) @default(0)
  paidAmount           Decimal        @db.Decimal(15, 2) @default(0)
  status               PurchaseStatus @default(DRAFT)
  approvedById         String?
  approvedAt           DateTime?
  notes                String?
  invoiceImageUrl      String?
  // New GRN fields
  invoiceControlTotal  Decimal?       @db.Decimal(15, 2)
  taxType              String         @default("TAX_EXCLUSIVE")
  itcEligibility       String         @default("ELIGIBLE")
  rcmApplicable        Boolean        @default(false)
  documentType         String         @default("INVOICE")
  placeOfSupply        String?
  isInterState         Boolean        @default(false)
  poNumber             String?
  billDiscountPercent  Decimal        @db.Decimal(5, 2)  @default(0)
  billDiscountAmount   Decimal        @db.Decimal(15, 2) @default(0)
  cashDiscountPercent  Decimal        @db.Decimal(5, 2)  @default(0)
  cashDiscountAmount   Decimal        @db.Decimal(15, 2) @default(0)
  freightCharges       Decimal        @db.Decimal(15, 2) @default(0)
  hamaliCharges        Decimal        @db.Decimal(15, 2) @default(0)
  otherCharges         Decimal        @db.Decimal(15, 2) @default(0)
  roundingAmount       Decimal        @db.Decimal(15, 2) @default(0)
  cessTotal            Decimal        @db.Decimal(15, 2) @default(0)
  advanceAdjusted      Decimal        @db.Decimal(15, 2) @default(0)
  amountPayable        Decimal        @db.Decimal(15, 2) @default(0)
  balanceAmount        Decimal        @db.Decimal(15, 2) @default(0)
  paymentDueDate       DateTime?
  paymentMode          String?
  paymentReference     String?
  paymentScreenshotUrl String?
  paymentNotes         String?
  amendmentVersion     Int            @default(1)
  originalGrnId        String?
  isAmendment          Boolean        @default(false)
  amendmentDeadline    DateTime?
  amendedById          String?
  amendedByName        String?
  amendedAt            DateTime?
  approvedByName       String?
  rejectedByName       String?
  excludeFromGst       Boolean        @default(false)
  receivedDate         DateTime?      @map("receiveddate")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  branch       Branch               @relation(fields: [branchId], references: [id])
  supplier     Supplier             @relation(fields: [supplierId], references: [id])
  items        PurchaseItem[]
  payments     SupplierPayment[]
  allocations  PaymentAllocation[]

  @@unique([businessId, invoiceNumber, supplierId])
  @@index([supplierId])
  @@index([status])
  @@map("purchase")
}

enum PurchaseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CANCELLED
}

// ─── PURCHASE ITEM ────────────────────────────────────
model PurchaseItem {
  id                      String    @id @default(cuid())
