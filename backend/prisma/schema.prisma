  disc1Percent            Decimal   @db.Decimal(8, 4)  @default(0)
  disc2Percent            Decimal   @db.Decimal(8, 4)  @default(0)
  disc3Percent            Decimal   @db.Decimal(8, 4)  @default(0)
  disc4Percent            Decimal   @db.Decimal(8, 4)  @default(0)
  cashDiscPercent         Decimal   @db.Decimal(8, 4)  @default(0)
  cashDiscAmount          Decimal   @db.Decimal(15, 2) @default(0)
  netCostPrice            Decimal   @db.Decimal(15, 2) @default(0)
  casesReceived           Decimal   @db.Decimal(10, 3) @default(0)
  looseQty                Decimal   @db.Decimal(10, 3) @default(0)
  packSize                Int       @default(1)
  totalReceivedQty        Decimal   @db.Decimal(10, 3) @default(0)
  freeCases               Decimal   @db.Decimal(10, 3) @default(0)
  freeLoose               Decimal   @db.Decimal(10, 3) @default(0)
  totalFreeQty            Decimal   @db.Decimal(10, 3) @default(0)
  totalQty                Decimal   @db.Decimal(10, 3) @default(0)
  cessRate                Decimal   @db.Decimal(5, 2)  @default(0)
