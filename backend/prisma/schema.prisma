  unitPrice               Decimal   @db.Decimal(15, 2)
  schemeDiscountPercent   Decimal   @db.Decimal(5, 2)  @default(0)
  retailerDiscountPercent Decimal   @db.Decimal(5, 2)  @default(0)
  taxableAmount           Decimal   @db.Decimal(15, 2) @default(0)
  gstRatePercent          Decimal   @db.Decimal(5, 2)  @default(0)
  cgstAmount              Decimal   @db.Decimal(15, 2) @default(0)
