// ─── STOCK LEDGER ─────────────────────────────────────
model StockLedger {
  id            String       @id @default(cuid())
  businessId    String
  branchId      String
  productId     String
  movementType  MovementType
  movementDate  DateTime     @default(now())
  quantity      Decimal      @db.Decimal(15, 3)
  referenceType String?
  referenceId   String?
  notes         String?
  createdAt     DateTime     @default(now())

  branch  Branch  @relation(fields: [branchId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([productId, branchId])
  @@index([movementDate])
  @@map("stock_ledger")
}

enum MovementType {
  PURCHASE
  SALE
  SALE_VOID
  SALE_RETURN
  OPENING_STOCK
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN_IN
  RETURN_OUT
  REPACKING_IN
  REPACKING_OUT
}

// ─── POS COUNTER & SHIFT ──────────────────────────────
model PosCounter {
  id         String        @id @default(cuid())
  businessId String
  branchId   String
  name       String
  code        String
  description String?
  status      CounterStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())

  business   Business    @relation(fields: [businessId], references: [id])
  branch     Branch      @relation(fields: [branchId], references: [id])
  shifts     PosShift[]
  salesBills SalesBill[]

  @@unique([businessId, code])
  @@map("pos_counter")
}

enum CounterStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model PosShift {
  id           String      @id @default(cuid())
  counterId    String
  cashierId    String
  cashierName  String?
  branchId     String?
  shiftDate    DateTime    @default(now())
  openingCash  Decimal     @db.Decimal(15, 2) @default(0)
  closingCash  Decimal?    @db.Decimal(15, 2)
  expectedCash Decimal?    @db.Decimal(15, 2)
  cashDiff     Decimal?    @db.Decimal(15, 2)
  totalSales   Decimal     @db.Decimal(15, 2) @default(0)
  totalBills   Int         @default(0)
  totalCash    Decimal     @db.Decimal(15, 2) @default(0)
  totalUpi     Decimal     @db.Decimal(15, 2) @default(0)
  totalCard    Decimal     @db.Decimal(15, 2) @default(0)
  status       ShiftStatus @default(OPEN)
  startTime    DateTime    @default(now())
  endTime      DateTime?
  notes        String?
  createdAt    DateTime    @default(now())

  counter    PosCounter  @relation(fields: [counterId], references: [id])
  cashier    User        @relation(fields: [cashierId], references: [id])
  salesBills SalesBill[]

  @@index([counterId, status])
  @@map("pos_shift")
}

enum ShiftStatus {
  OPEN
  CLOSED
  SUSPENDED
}

// ─── EXPENSE ──────────────────────────────────────────
model Expense {
  id          String   @id @default(cuid())
  businessId  String
  branchId    String?
  expenseDate DateTime @default(now())
  category    String?
  amount      Decimal  @db.Decimal(15, 2)
  paymentMode String   @default("CASH")
  vendorName  String?
  referenceNo String?
  description String?
  remarks     String?
  createdAt   DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])

  @@map("expense")
}

// ─── AUDIT LOG ────────────────────────────────────────
model AuditLog {
  id          String   @id @default(cuid())
  businessId  String
  userId      String?
  userName    String
  userRole    String
  action      String   // CREATE UPDATE DELETE APPROVE REJECT STATUS_CHANGE LOGIN OPEN CLOSE
  entity      String   // BILL GRN PRODUCT CUSTOMER SUPPLIER EXPENSE ONLINE_ORDER USER SHIFT INVENTORY SETTINGS
  entityId    String?
  entityRef   String?
  description String
  meta        Json?
  createdAt   DateTime @default(now())

  @@index([businessId, createdAt(sort: Desc)])
  @@index([businessId, entity])
  @@index([userId])
  @@map("audit_log")
}

// ─── NOTIFICATION ────────────────────────────────────
model Notification {
  id          String    @id @default(cuid())
  businessId  String
  type        String
  // OUT_OF_STOCK, LOW_STOCK, RESTOCKED, GRN_PENDING, GRN_APPROVED, GRN_REJECTED, PAYMENT_DUE, SYSTEM
  priority    String    @default("NORMAL")
  // LOW, NORMAL, HIGH, URGENT
  title       String
  message     String
  productId   String?
  supplierId  String?
  purchaseId  String?
  actionUrl   String?
  actionLabel String?
  isRead      Boolean   @default(false)
  readAt      DateTime?
  readById    String?
  channel     String    @default("IN_APP")
  createdAt   DateTime  @default(now())

  business    Business  @relation(fields: [businessId], references: [id])

  @@index([businessId, isRead])
  @@index([businessId, createdAt])
  @@map("notification")
}

// ─── DAY CLOSURE ─────────────────────────────────────
model DayClosure {
  id             String    @id @default(cuid())
  businessId     String
  branchId       String
  closureDate    DateTime  @db.Date
  status         String    @default("PENDING")
  // PENDING, COMPLETED, AUTO_CLOSED

  systemCash     Decimal   @db.Decimal(15, 2) @default(0)
  actualCash     Decimal?  @db.Decimal(15, 2)
  cashDifference Decimal?  @db.Decimal(15, 2)

  totalBills     Int       @default(0)
  totalSales     Decimal   @db.Decimal(15, 2) @default(0)
  totalCash      Decimal   @db.Decimal(15, 2) @default(0)
  totalUpi       Decimal   @db.Decimal(15, 2) @default(0)
  totalCard      Decimal   @db.Decimal(15, 2) @default(0)

  cashCounted    Boolean   @default(false)
  grnsPending    Int       @default(0)
  grnsCleared    Boolean   @default(false)
  stockAlertsAck Boolean   @default(false)

  openedById     String?
  openedByName   String?
  closedById     String?
  closedAt       DateTime?
  notes          String?

  createdAt      DateTime  @default(now())

  business       Business  @relation(fields: [businessId], references: [id])

  @@unique([businessId, branchId, closureDate])
  @@index([businessId, closureDate])
  @@map("day_closure")
}

// ─── HELD BILLS ──────────────────────────────────────
model HeldBill {
  id              String   @id @default(cuid())
  holdNumber      String
  businessId      String
  branchId        String
  createdByUserId String
  createdByName   String
  counterName     String
  billType        String   @default("TAX_INVOICE")
  customerId      String?
  customerName    String?
  customerPhone   String?
  customerGstin   String?
  isB2B           Boolean  @default(false)
  itemsJson       String
  subtotal        Decimal  @db.Decimal(15, 2)
  grandTotal      Decimal  @db.Decimal(15, 2)
  itemCount       Int
  status          String   @default("HELD")
  heldAt          DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessId, status])
  @@map("held_bill")
}

// ─── CREDIT NOTE ─────────────────────────────────────
model CreditNote {
  id                 String          @id @default(cuid())
  creditNoteNumber   String          @unique
  businessId         String
  branchId           String
  originalBillId     String
  originalBillNumber String
  customerId         String?
  customerName       String?
  customerPhone      String?
  reason             String
  subtotalAmount     Decimal         @db.Decimal(15, 2)
  taxAmount          Decimal         @db.Decimal(15, 2)
  cgstAmount         Decimal         @db.Decimal(15, 2)
  sgstAmount         Decimal         @db.Decimal(15, 2)
  totalAmount        Decimal         @db.Decimal(15, 2)
  refundMode         String          // CASH or STORE_CREDIT
  refundStatus       String          @default("PENDING")
  refundCompletedAt  DateTime?
  createdById        String
  createdByName      String
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  items CreditNoteItem[]

  @@index([businessId, originalBillId])
  @@index([businessId, createdAt])
  @@map("credit_note")
}

model CreditNoteItem {
  id             String     @id @default(cuid())
  creditNoteId   String
  creditNote     CreditNote @relation(fields: [creditNoteId], references: [id])
  productId      String
  productName    String
  hsnCode        String?
  quantity       Decimal    @db.Decimal(15, 3)
  unitPrice      Decimal    @db.Decimal(15, 2)
  gstRatePercent Decimal    @db.Decimal(5, 2)
  cgstAmount     Decimal    @db.Decimal(15, 2)
  sgstAmount     Decimal    @db.Decimal(15, 2)
  totalAmount    Decimal    @db.Decimal(15, 2)
  isReturnable   Boolean    @default(true)

  @@map("credit_note_item")
}

// ─── SETTINGS ────────────────────────────────────────
model SystemSetting {
  id         String   @id @default(cuid())
  businessId String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business   Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, key])
  @@map("system_setting")
}

// ─── PLU BUNDLE (Bulk ↔ Single linking) ──────────────
model PluBundle {
  id              String   @id @default(cuid())
  businessId      String
  bulkPluId       String   @unique   // e.g. PLU 000278002 (box of 10)
  singlePluId     String             // e.g. PLU 000278001 (single blade)
  conversionQty   Int                // 1 bulk = conversionQty singles
  notes           String?            // "1 box = 10 blades"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bulkPlu   ProductPlu @relation("BulkPlu",   fields: [bulkPluId],   references: [id])
  singlePlu ProductPlu @relation("SinglePlu", fields: [singlePluId], references: [id])

  @@index([businessId])
  @@index([singlePluId])
  @@map("plu_bundle")
}

// ─── BREAK BULK LOG ───────────────────────────────────
model BreakBulkLog {
  id              String   @id @default(cuid())
  businessId      String
  pluBundleId     String
  bulkPluId       String
  singlePluId     String
  bulkQtyBroken   Int                // how many bulk units were broken
  singlesCreated  Int                // = bulkQtyBroken × conversionQty
  notes           String?
  createdById     String?
  createdByName   String?
  createdAt       DateTime @default(now())

  @@index([businessId, createdAt])
  @@map("break_bulk_log")
}

// ─── PRODUCT PLU ──────────────────────────────────────
model ProductPlu {
  id                String    @id @default(cuid())
  businessId        String
  productId         String
  pluCode           String
  displayName       String?
  // Cost & price fields
  costPrice         Decimal   @db.Decimal(15, 2)
  basicCost         Decimal?  @db.Decimal(15, 2)
  mrp               Decimal   @db.Decimal(15, 2)
  sellingPrice      Decimal   @db.Decimal(15, 2)
  wholesalePrice    Decimal?  @db.Decimal(15, 2)
  minSellingPrice   Decimal   @db.Decimal(15, 2) @default(0)
  // Tax fields
  gstRate           Decimal?  @db.Decimal(5, 2)
  cessRate          Decimal   @db.Decimal(5, 2)  @default(0)
  taxInclusive      Boolean   @default(false)
  // Margin fields
  marginPercent     Decimal?  @db.Decimal(8, 4)
  marginRs          Decimal?  @db.Decimal(15, 2)
  // Barcode
  eanCode           String?
  hsnCode           String?
  // GRN linkage
  grnId             String?
  supplierId        String?
  batchNumber       String?
  manufacturingDate DateTime?
  expiryDate        DateTime?
  receivedDate      DateTime  @default(now())
  effectiveFrom     DateTime  @default(now())
  // Stock fields
  receivedQty       Decimal   @db.Decimal(10, 3) @default(0)
  soldQty           Decimal   @db.Decimal(10, 3) @default(0)
  stockOnHand       Decimal   @db.Decimal(10, 3) @default(0)
  // Online catalog fields
  availableOnline   Boolean   @default(false)
  onlinePrice       Decimal?  @db.Decimal(15, 2)
  onlineStockCap    Int?      // null = no cap (sell up to totalStock); set to limit online channel
  // Status flags
  isDefault         Boolean   @default(false)
  isActive          Boolean   @default(true)
  isArchived        Boolean   @default(false)
  archivedAt        DateTime?
  archivedReason    String?
  createdById       String?
  createdByName     String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  product   Product         @relation(fields: [productId], references: [id])
  business  Business        @relation(fields: [businessId], references: [id])
  barcodes  ProductBarcode[]
  asBulk    PluBundle?      @relation("BulkPlu")
  asSingle  PluBundle[]     @relation("SinglePlu")

  @@unique([businessId, pluCode])
  @@index([productId])
  @@index([businessId])
  @@index([pluCode])
  @@map("product_plu")
}

// ─── SUPPLIER ITEM ALIAS ──────────────────────────────
model SupplierItemAlias {
  id           String   @id @default(cuid())
  businessId   String
  supplierId   String
  productId    String
  supplierCode String?
  supplierName String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])
  business Business @relation(fields: [businessId], references: [id])

  @@unique([supplierId, productId])
  @@index([businessId, supplierId])
  @@map("supplier_item_alias")
}

// ─── SUPPLIER ADVANCE ─────────────────────────────────
model SupplierAdvance {
  id             String    @id @default(cuid())
  businessId     String
  supplierId     String
  amount         Decimal   @db.Decimal(15, 2)
  adjustedAmount Decimal   @db.Decimal(15, 2) @default(0)
  balanceAmount  Decimal   @db.Decimal(15, 2)
  paymentMode    String
  paymentDate    DateTime
  referenceNo    String?
  notes          String?
  screenshotUrl  String?
  status         String    @default("AVAILABLE")
  createdById    String?
  createdByName  String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  supplier    Supplier                   @relation(fields: [supplierId], references: [id])
  business    Business                   @relation(fields: [businessId], references: [id])
  adjustments SupplierAdvanceAdjustment[]

  @@index([businessId, supplierId])
  @@map("supplier_advance")
}

model SupplierAdvanceAdjustment {
  id             String   @id @default(cuid())
  advanceId      String
  purchaseId     String
  adjustedAmount Decimal  @db.Decimal(15, 2)
  adjustedAt     DateTime @default(now())
  notes          String?

  advance SupplierAdvance @relation(fields: [advanceId], references: [id])

  @@map("supplier_advance_adjustment")
}

// ─── SUPPLIER CREDIT NOTE ─────────────────────────────
model SupplierCreditNote {
  id                String   @id @default(cuid())
  businessId        String
  scnNumber         String   @unique
  supplierId        String
  originalGrnId     String?
  originalInvoiceNo String?
  supplierCnNumber  String?
  cnDate            DateTime
  reason            String
  taxableAmount     Decimal  @db.Decimal(15, 2) @default(0)
  cgstAmount        Decimal  @db.Decimal(15, 2) @default(0)
  sgstAmount        Decimal  @db.Decimal(15, 2) @default(0)
  igstAmount        Decimal  @db.Decimal(15, 2) @default(0)
  cessAmount        Decimal  @db.Decimal(15, 2) @default(0)
  totalAmount       Decimal  @db.Decimal(15, 2)
  itcReversal       Boolean  @default(false)
  status            String   @default("PENDING")
  notes             String?
  createdById       String?
  createdByName     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id])
  business Business @relation(fields: [businessId], references: [id])
  items    SupplierCreditNoteItem[]

  @@index([businessId, supplierId])
  @@map("supplier_credit_note")
}

model SupplierCreditNoteItem {
  id           String  @id @default(cuid())
  creditNoteId String
  productId    String?
  productName  String
  hsnCode      String?
  quantity     Decimal @db.Decimal(10, 3)
  unitPrice    Decimal @db.Decimal(15, 2)
  gstRate      Decimal @db.Decimal(5, 2)  @default(0)
  cessRate     Decimal @db.Decimal(5, 2)  @default(0)
  gstAmount    Decimal @db.Decimal(15, 2) @default(0)
  cessAmt      Decimal @db.Decimal(15, 2) @default(0)
  totalAmount  Decimal @db.Decimal(15, 2)

  creditNote SupplierCreditNote @relation(fields: [creditNoteId], references: [id])

  @@index([creditNoteId])
  @@map("supplier_credit_note_item")
}

// ─── SUPPLIER PAYMENT ─────────────────────────────────
model SupplierPayment {
  id               String    @id @default(cuid())
  businessId       String
  supplierId       String
  purchaseId       String?   // primary GRN (for single-GRN payments)
  invoiceReference String?
  paymentDate      DateTime  @default(now())
  amount           Decimal   @db.Decimal(15, 2)
  paymentMode      String    @default("NEFT")  // NEFT / UPI / CASH / CHEQUE
  referenceNumber  String?
  utrNumber        String?   // UTR / transaction ID from bank
  epayOrderNumber  String?   // PhonePe / GPay / e-pay order or transaction number
  bankAccountId    String?   // which bank account this was paid from
  bankTransactionId String?  // linked bank statement transaction
  matchedFromStatement Boolean @default(false)
  adjustmentAmount Decimal   @default(0) @db.Decimal(15, 2)  // signed gap: +charge, -TDS/discount
  adjustmentReason String?   // BANK_CHARGE / TDS / CASH_DISCOUNT / ROUNDING / SHORT_PAYMENT
  proofToken       String?   @unique  // public read-only token for vendor share link
  notes            String?
  screenshotUrl    String?
  status           String    @default("COMPLETED") // COMPLETED / CANCELLED
  createdById      String?
  createdByName    String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  business         Business              @relation(fields: [businessId], references: [id])
  supplier         Supplier              @relation(fields: [supplierId], references: [id])
  purchase         Purchase?             @relation(fields: [purchaseId], references: [id])
  allocations      PaymentAllocation[]   // which GRNs this payment covers
  bankTransaction  BankTransaction[]     @relation

  @@index([businessId, supplierId])
  @@index([businessId, purchaseId])
  @@index([paymentDate])
  @@index([bankTransactionId])
  @@map("supplier_payment")
}

// ─── PAYMENT ALLOCATION ───────────────────────────────
// One payment can cover multiple GRNs (partial or full)
model PaymentAllocation {
  id              String          @id @default(cuid())
  paymentId       String
  purchaseId      String
  allocatedAmount Decimal         @db.Decimal(15, 2)
  createdAt       DateTime        @default(now())

  payment  SupplierPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  purchase Purchase        @relation(fields: [purchaseId], references: [id])

  @@unique([paymentId, purchaseId])
  @@index([purchaseId])
  @@map("payment_allocation")
}

// ─── CUSTOMER ADDRESS ────────────────────────────────
model CustomerAddress {
  id         String   @id @default(cuid())
  businessId String
  customerId String
  label      String?
  line1      String
  line2      String?
  city       String?
  state      String?
  pincode    String?
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("customer_address")
}

// ─── BANK ACCOUNT ────────────────────────────────────
model BankAccount {
  id             String   @id @default(cuid())
  businessId     String
  accountName    String   // "SBI CC Account", "IDBI Current"
  bankName       String   // "State Bank of India"
  accountNumber  String
  accountType    String   @default("CURRENT") // CURRENT / SAVINGS / CC / OD
  ifscCode       String?
  branchName     String?
  openingBalance Decimal  @db.Decimal(15, 2) @default(0)
  currentBalance Decimal  @db.Decimal(15, 2) @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  business     Business              @relation(fields: [businessId], references: [id])
  transactions BankTransaction[]
  imports      BankStatementImport[]

  @@index([businessId])
  @@map("bank_account")
}

// ─── BANK STATEMENT IMPORT BATCH ─────────────────────
model BankStatementImport {
  id             String   @id @default(cuid())
  businessId     String
  bankAccountId  String
  fileName       String
  fromDate       DateTime
  toDate         DateTime
  openingBalance Decimal  @db.Decimal(15, 2) @default(0)
  closingBalance Decimal  @db.Decimal(15, 2) @default(0)
  totalCredits   Decimal  @db.Decimal(15, 2) @default(0)
  totalDebits    Decimal  @db.Decimal(15, 2) @default(0)
  txnCount       Int      @default(0)
  importedById   String?
  importedAt     DateTime @default(now())

  bankAccount  BankAccount       @relation(fields: [bankAccountId], references: [id])
  transactions BankTransaction[]

  @@index([bankAccountId])
  @@map("bank_statement_import")
}

// ─── BANK TRANSACTION ─────────────────────────────────
model BankTransaction {
  id            String    @id @default(cuid())
  businessId    String
  bankAccountId String
  importId      String?
  txnDate       DateTime
  valueDate     DateTime?
  description   String
  refNumber     String?
  branchCode    String?
  debitAmount   Decimal?  @db.Decimal(15, 2)
  creditAmount  Decimal?  @db.Decimal(15, 2)
  balance       Decimal?  @db.Decimal(15, 2)

  // Auto-categorization
  txnType     String @default("UNCATEGORIZED")
  // SALES_PHONEPE | SALES_PINELABS | SALES_UPI | CASH_DEPOSIT
  // SUPPLIER_PAYMENT | EXPENSE_RENT | EXPENSE_OTHER
  // TRANSFER_PERSONAL | UNCATEGORIZED

  // Matching to supplier payment
  matchStatus        String  @default("UNMATCHED") // UNMATCHED / MATCHED / IGNORED
  supplierId         String?
  supplierPaymentId  String?
  matchedBySystem    Boolean @default(false)
  notes              String?

  business         Business             @relation(fields: [businessId], references: [id])
  bankAccount      BankAccount          @relation(fields: [bankAccountId], references: [id])
  import           BankStatementImport? @relation(fields: [importId], references: [id])
  supplierPayment  SupplierPayment?     @relation(fields: [supplierPaymentId], references: [id])

  @@index([bankAccountId, txnDate])
  @@index([matchStatus])
  @@index([businessId])
  @@map("bank_transaction")
}

// ─── CUSTOMER PAYMENT ────────────────────────────────
model CustomerPayment {
  id            String    @id @default(cuid())
  businessId    String
  customerId    String
  amount        Decimal   @db.Decimal(15, 2)
  paymentMode   String
  reference     String?
  notes         String?
  billId        String?
  paymentDate   DateTime  @default(now())
  createdBy     String
  createdByName String?
  createdAt     DateTime  @default(now())

  customer Customer   @relation(fields: [customerId], references: [id])
  bill     SalesBill? @relation(fields: [billId], references: [id])

  @@index([customerId])
  @@index([businessId, paymentDate])
  @@map("customer_payment")
}

// ─── ONLINE ORDERS ────────────────────────────────────

enum DeliveryType {
  HOME_DELIVERY
  STORE_PICKUP
}

enum OnlineOrderStatus {
  PENDING_PAYMENT
  PENDING_COD
  CONFIRMED
  PROCESSING
  READY
  DELIVERED
  CANCELLED
  PAYMENT_FAILED
}

enum OnlinePaymentMethod {
  RAZORPAY
  COD
}

enum OnlinePaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model StorefrontAddress {
  id        String   @id @default(cuid())
  phone     String
  label     String   @default("Home")
  line1     String
  line2     String?
  city      String
  pincode   String
  state     String   @default("Telangana")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@map("storefront_address")
}

model OnlineOrder {
  id                String              @id @default(cuid())
  orderNumber       String              @unique
  businessId        String
  customerName      String
  customerPhone     String
  customerEmail     String?
  deliveryType      DeliveryType
  deliveryAddress   Json?
  paymentMethod     OnlinePaymentMethod
  paymentStatus     OnlinePaymentStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  subtotal          Decimal             @db.Decimal(10, 2)
  deliveryFee       Decimal             @default(0) @db.Decimal(10, 2)
  total             Decimal             @db.Decimal(10, 2)
  status            OnlineOrderStatus   @default(PENDING_PAYMENT)
  customerNotes     String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  business Business          @relation(fields: [businessId], references: [id])
  items    OnlineOrderItem[]

  @@index([businessId])
  @@index([customerPhone])
  @@index([createdAt])
  @@map("online_order")
}

model OnlineOrderItem {
  id          String   @id @default(cuid())
  orderId     String
  pluBarcode  String
  productCode String
  productName String
  packLabel   String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(10, 2)
  total       Decimal  @db.Decimal(10, 2)
  mrp         Decimal? @db.Decimal(10, 2)

  order OnlineOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("online_order_item")
}

// ─── STOREFRONT CUSTOMER PROFILE ────────────────────
model StorefrontProfile {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  phone          String?
  alternatePhone String?
  photoUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([phone])
  @@map("storefront_profile")
}

// ─── WHATSAPP INCOMING LISTS ─────────────────────────────────────────────────
model WaIncomingList {
  id           String   @id @default(cuid())
  businessId   String

  // Sender
  senderPhone  String
  senderName   String?

  // Message content
  msgType      String            // TEXT | IMAGE | DOCUMENT | PDF
  rawText      String?           // original typed text
  ocrText      String?           // OCR extracted from image
  mediaId      String?           // Meta media ID
  mediaPath    String?           // saved file path on server
  mediaMime    String?

  // Generated doc
  docPath      String?           // .docx file path on server
  docReady     Boolean           @default(false)

  // Workflow
  status       String            @default("PENDING") // PENDING | PROCESSING | READY | DOWNLOADED
  errorMsg     String?

  receivedAt   DateTime          @default(now())
  processedAt  DateTime?

  business     Business          @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([senderPhone])
  @@index([status])
  @@map("wa_incoming_list")
}

