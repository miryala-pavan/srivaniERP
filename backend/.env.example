DATABASE_URL="postgresql://<user>:<password>@localhost:4432/<dbname>"

JWT_SECRET=<replace-with-strong-random-secret>
JWT_EXPIRES_IN=12h
PORT=4001
NODE_ENV=development
FRONTEND_URL=http://localhost:4000

# Optional Redis URL for shop-layer caching (nav-tree, categories, departments, single products).
# If unset or Redis is unavailable the shop falls back to direct DB queries silently.
# Example (local):  REDIS_URL=redis://127.0.0.1:6379
# Example (cloud):  REDIS_URL=rediss://:<password>@<host>:6380
# REDIS_URL=redis://127.0.0.1:6379

# Razorpay credentials (required for online payment; COD works without these).
# Get your keys from https://dashboard.razorpay.com/app/keys
# Use test keys (rzp_test_...) in development, live keys (rzp_live_...) in production.
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Absolute path to the directory where product images are stored.
# This directory is served as static assets at /uploads/products/<filename>.
# IMPORTANT: Include this directory in your backup routine alongside pg_dump.
# Place noimage.svg (or noimage.png) here as the placeholder for products without images.
# Example (Windows): PRODUCT_IMAGES_DIR=J:\SVN\SVN_26\storage\product-images
# Example (Linux):   PRODUCT_IMAGES_DIR=/var/srivani/storage/product-images
PRODUCT_IMAGES_DIR=J:\SVN\SVN_26\storage\product-images

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
# Free: 1,000 conversations/month. No monthly fee.
# Orders work without these — WhatsApp is a silent no-op if unset.
#
# SETUP (one-time, ~30 minutes):
#   1. Go to https://developers.facebook.com → My Apps → Create App
#   2. App type: Business  →  Add product: WhatsApp
#   3. WhatsApp → API Setup:
#        - Copy "Temporary access token"  → WA_ACCESS_TOKEN (valid 24h for testing)
#        - Copy "Phone number ID"         → WA_PHONE_NUMBER_ID
#        - Add your mobile as "Test recipient"
#   4. For production: create a System User token in Meta Business Manager
#        (Business Settings → System Users → Add → Generate token → select app → whatsapp_business_messaging)
#
# TEST (verify credentials before creating templates):
#   POST /api/notifications/whatsapp/test   { "phone": "9XXXXXXXXX" }
#   This sends the pre-approved "hello_world" template — no template setup needed.
#
# TEMPLATES (create these in Meta Business Manager → WhatsApp → Message Templates):
#
#   1. Name: svn_order_placed  | Category: TRANSACTIONAL | Language: English
#      Body:
#        Hello {{1}}, your order *{{2}}* has been placed at Srivani Stores! 🎉
#        Total: ₹{{3}} | {{4}}
#        We will keep you updated. Thank you for shopping with us! 🙏
#
#   2. Name: svn_payment_done  | Category: TRANSACTIONAL | Language: English
#      Body:
#        Hello {{1}}, payment of ₹{{2}} received! ✅
#        Order *{{3}}* is confirmed. We will start preparing it now.
#        - Srivani Stores
#
#   3. Name: svn_order_update  | Category: TRANSACTIONAL | Language: English
#      Body:
#        Hello {{1}},
#        Your order *{{2}}* update:
#        {{3}}
#        - Team Srivani Stores
#
#   4. Name: test_order  | Category: TRANSACTIONAL | Language: English  (store alert)
#      Body:
#        New order {{1}} from {{2}} ({{3}}).
#        Items: {{4}} | Total: ₹{{5}} | {{6}} | {{7}}
#
# WA_ACCESS_TOKEN=
# WA_PHONE_NUMBER_ID=
# WA_STORE_NOTIFY_NUMBER=91XXXXXXXXXX
