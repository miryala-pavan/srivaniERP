DATABASE_URL="postgresql://<user>:<password>@localhost:4432/<dbname>"

JWT_SECRET=<replace-with-strong-random-secret>
JWT_EXPIRES_IN=12h
PORT=4001
NODE_ENV=development
FRONTEND_URL=http://localhost:4000

# Absolute path to the directory where product images are stored.
# This directory is served as static assets at /uploads/products/<filename>.
# IMPORTANT: Include this directory in your backup routine alongside pg_dump.
# Place noimage.svg (or noimage.png) here as the placeholder for products without images.
# Example (Windows): PRODUCT_IMAGES_DIR=J:\SVN\SVN_26\storage\product-images
# Example (Linux):   PRODUCT_IMAGES_DIR=/var/srivani/storage/product-images
PRODUCT_IMAGES_DIR=J:\SVN\SVN_26\storage\product-images
